<% content_for :title, (import_file_flow? && !sales_mode? ? "Journey Tracking" : "Stock") %>

<% total_count = import_file_flow? && !sales_mode? ? @all_count : @all_stock_items.size %>
<% ordered_count = import_file_flow? && !sales_mode? ? @ordered_count : @all_stock_items.count(&:status_ordered?) %>
<% incoming_count = import_file_flow? && !sales_mode? ? @incoming_count : @all_stock_items.count(&:status_incoming?) %>
<% tab_links = [
  [ "all", "ทั้งหมด", total_count ],
  [ "ordered", (import_file_flow? && !sales_mode? ? import_stage_tab_label(@tracking_report_type, "ordered") : "สั่งเข้าแล้ว"), ordered_count ],
  [ "incoming", (import_file_flow? && !sales_mode? ? import_stage_tab_label(@tracking_report_type, "incoming") : "กำลังเข้า"), incoming_count ]
] %>

<section class="space-y-8">
  <div class="app-soft-card flex flex-col gap-6 rounded-xl border p-8 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">
          <%= sales_mode? ? "Sales Workspace" : (import_file_flow? ? "Import Journey" : "Stock Workspace") %>
        </p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900"><%= sales_mode? ? "รถที่กำลังเข้า" : (import_file_flow? ? import_stage_title(@tracking_report_type) : "Stock") %></h1>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-stone-600">
          <% if sales_mode? %>
            มุมมองนี้แสดงเฉพาะรถที่เริ่มมีความชัดว่าจะเข้าจริงแล้ว เพื่อให้ฝ่ายขายติดตามรถที่กำลังเข้า วางแผนเสนอขาย และบันทึกความสนใจของแต่ละสาขาโดยไม่ต้องเห็นข้อมูลเอกสารฝั่งจัดสรร
          <% elsif import_file_flow? %>
            มุมมองนี้รวมข้อมูลของ stage ล่าสุดที่นำเข้ามา เพื่อให้ฝ่ายจัดสรรติดตามว่าหลัง upload แล้ว รายการไหนยังอยู่ใน <%= import_stage_label(@tracking_report_type) %> และรายการไหนเริ่มพร้อมใช้ต่อใน stage ถัดไป
          <% else %>
            มุมมองนี้รวมข้อมูล stock ที่ฝ่ายจัดสรรสั่งไว้และรายการที่เริ่มไหลเป็น stock กำลังเข้าแล้วในหน้าเดียว
            เพื่อให้เห็นเส้นทางจากความต้องการภายใน ไปสู่ pipeline ที่ฝ่ายขายใช้งานต่อได้
          <% end %>
        </p>
      </div>

      <% unless import_file_flow? && !sales_mode? %>
        <%= form_with url: check_latest_stock_orders_path(tab: (@active_tab == "all" ? nil : @active_tab)),
                      method: :post,
                      class: "flex flex-wrap items-center gap-3",
                      data: {
                        controller: "sync-feedback",
                        action: "turbo:submit-start->sync-feedback#start turbo:submit-end->sync-feedback#reset",
                        sync_feedback_message_value: (
                          if sales_mode?
                            "กำลังเช็คข้อมูลล่าสุดเพื่ออัปเดตรถที่กำลังเข้าสำหรับฝ่ายขาย..."
                          else
                            "กำลังเช็คข้อมูลล่าสุดจากบริษัทแม่และอัปเดตสถานะ stock..."
                          end
                        )
                      } do %>
          <button type="submit"
                  data-sync-feedback-target="button"
                  data-turbo-submits-with="กำลังเช็คสถานะ..."
                  class="app-btn-secondary inline-flex cursor-pointer items-center gap-2 rounded-2xl px-4 py-3 text-sm font-medium transition disabled:cursor-wait disabled:bg-stone-500">
            <span class="inline-flex h-2.5 w-2.5 rounded-full bg-white/80"></span>
            <span><%= sales_mode? ? "เช็คสถานะล่าสุดสำหรับฝ่ายขาย" : "เช็คสถานะล่าสุด" %></span>
          </button>
          <div data-sync-feedback-target="panel" class="hidden rounded-2xl border border-[#fecdd3] bg-[#fff1f2] px-4 py-3 text-sm text-[#be123c]">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-3 w-3 animate-pulse rounded-full bg-[#e20712]"></span>
              <span data-sync-feedback-target="label">กำลังเช็คสถานะล่าสุด...</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <% unless sales_mode? %>
      <div class="flex flex-wrap items-center gap-3 border-t border-stone-200 pt-5">
        <% tab_links.each do |tab_key, label, count| %>
          <% classes = @active_tab == tab_key ? "app-tab-active" : "app-tab-inactive" %>
          <%= link_to stock_orders_path(tab: (tab_key == "all" ? nil : tab_key)),
                      class: "#{classes} inline-flex items-center rounded-full px-4 py-2 text-sm font-medium transition" do %>
            <span><%= label %></span>
            <span class="ml-2 rounded-full bg-white/20 px-2 py-0.5 text-xs"><%= count %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <div class="app-soft-card rounded-lg border p-6 shadow-sm">
      <p class="text-sm text-stone-500"><%= sales_mode? ? "รถที่กำลังเข้า" : (import_file_flow? ? "รายการใน stage นี้" : "รายการในมุมมองนี้") %></p>
      <p class="mt-3 text-3xl font-semibold text-stone-900"><%= @stock_items.size %></p>
    </div>
    <div class="app-soft-card rounded-lg border p-6 shadow-sm">
      <p class="text-sm text-stone-500"><%= sales_mode? ? "รถที่มีเซลล์ติดตาม" : (import_file_flow? ? import_stage_pending_label(@tracking_report_type) : "สั่งเข้าแล้ว") %></p>
      <p class="mt-3 text-3xl font-semibold text-stone-900"><%= sales_mode? ? @sales_followed_count : ordered_count %></p>
    </div>
    <div class="app-soft-card rounded-lg border p-6 shadow-sm">
      <p class="text-sm text-stone-500"><%= sales_mode? ? "รถที่มีลูกค้ามุ่งหวัง/จอง" : (import_file_flow? ? import_stage_ready_label(@tracking_report_type) : "กำลังเข้า") %></p>
      <p class="mt-3 text-3xl font-semibold text-stone-900"><%= sales_mode? ? @sales_customer_waiting_count : incoming_count %></p>
    </div>
    <div class="rounded-lg border border-[#fecdd3] bg-[#fff1f2] p-6 shadow-sm">
      <p class="text-sm text-[#be123c]"><%= import_file_flow? && !sales_mode? ? "Qty ใน stage นี้" : "Qty รวม" %></p>
      <p class="mt-3 text-3xl font-semibold text-[#881337]"><%= import_file_flow? && !sales_mode? ? @stock_items.sum { |forecast| forecast.quantity_available.to_i } : @stock_items.sum(&:selected_quantity) %></p>
    </div>
  </div>

  <div class="app-soft-card overflow-hidden rounded-lg border shadow-sm">
    <div class="border-b border-stone-200 px-6 py-4">
      <% if sales_mode? %>
        <h2 class="text-lg font-semibold text-stone-900">รายการรถที่ฝ่ายขายดูได้ตอนนี้</h2>
        <p class="mt-1 text-sm text-stone-500">แสดงเฉพาะ incoming vehicles ที่เริ่มใช้วางแผนเสนอขายได้ โดยตัดข้อมูลเอกสารภายในของฝ่ายจัดสรรออก</p>
      <% else %>
        <% if import_file_flow? %>
          <h2 class="text-lg font-semibold text-stone-900"><%= import_stage_collection_title(@tracking_report_type, @active_tab) %></h2>
          <p class="mt-1 text-sm text-stone-500"><%= import_stage_collection_description(@tracking_report_type, @active_tab) %></p>
        <% else %>
          <h2 class="text-lg font-semibold text-stone-900">
            <%=
              case @active_tab
              when "ordered" then "รายการที่สั่งเข้า Stock แล้ว"
              when "incoming" then "รายการที่กลายเป็น Stock กำลังเข้า"
              else "รายการ Stock ทั้งหมดใน flow"
              end
            %>
          </h2>
          <p class="mt-1 text-sm text-stone-500">
            <%=
              case @active_tab
              when "ordered" then "ใช้ติดตามรายการที่ฝ่ายจัดสรรสั่งไว้แล้ว แต่ยังรอข้อมูลจากบริษัทแม่ให้ครบขึ้น"
              when "incoming" then "ใช้ติดตาม pipeline stock ที่เริ่มมี Qty, Prod. Date และ ETA ชัดเจนแล้ว"
              else "มองข้อมูลชุดเดียวกันแบบต่อเนื่อง ตั้งแต่สั่งเข้าไปจนเริ่มกลายเป็น stock กำลังเข้า"
              end
            %>
          </p>
        <% end %>
      <% end %>
    </div>

    <% if @stock_items.blank? %>
      <div class="px-6 py-12 text-center">
        <p class="text-base font-medium text-stone-900">ยังไม่มีรายการในมุมมองนี้</p>
        <p class="mt-2 text-sm text-stone-500">
          <%= if sales_mode?
                "รอให้ฝ่ายจัดสรรสั่งเข้า stock และเช็คสถานะล่าสุดก่อน"
              elsif import_file_flow?
                "ลองกลับไปที่หน้า Import Stages เพื่อจำลองการนำเข้า PRE_ASS_SCDL, ASS_SCDL หรือ DAILY_INV ก่อน"
              else
                "ลองกลับไปที่ Forecast เพื่อสั่งเข้า Stock ก่อน หรือกด Sync เพื่อจำลองข้อมูลตอบกลับจากบริษัทแม่"
              end %>
        </p>
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-stone-200 text-sm">
          <thead class="bg-stone-50 text-left text-stone-500">
            <tr>
              <% unless import_file_flow? && !sales_mode? %>
                <th class="px-5 py-3 font-medium">Stock</th>
              <% end %>
              <th class="px-5 py-3 font-medium">Model</th>
              <th class="px-5 py-3 font-medium">Color</th>
              <% if import_file_flow? && !sales_mode? %>
                <th class="px-5 py-3 font-medium">แหล่งข้อมูลล่าสุด</th>
                <th class="px-5 py-3 font-medium">Prod. Date</th>
                <th class="px-5 py-3 font-medium">ETA</th>
              <% else %>
                <th class="px-5 py-3 font-medium">Location</th>
              <% end %>
              <th class="px-5 py-3 font-medium text-right">Qty</th>
              <% if sales_mode? %>
                <th class="px-5 py-3 font-medium">In Stock</th>
                <th class="px-5 py-3 font-medium">เซลล์ที่ติดตาม</th>
                <th class="px-5 py-3 font-medium">Action</th>
              <% else %>
                <th class="px-5 py-3 font-medium">สถานะ</th>
                <% unless import_file_flow? %>
                  <th class="px-5 py-3 font-medium">รายการสั่งเข้า Stock</th>
                <% end %>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100 bg-white">
            <% @stock_items.each do |row| %>
              <% if import_file_flow? && !sales_mode? %>
                <% forecast = row %>
                <tr class="hover:bg-stone-50/80">
                  <td class="px-5 py-4">
                    <div class="font-medium text-stone-900"><%= forecast.model_label || forecast.model_code %></div>
                    <div class="text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></div>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <%= forecast_color_swatch(forecast) %>
                      <div class="font-medium text-stone-900"><%= forecast.color_name || "-" %></div>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-5 py-4">
                    <% feed_badge_label, feed_badge_classes = import_source_badge(forecast) %>
                    <span class="<%= feed_badge_classes %> inline-flex items-center rounded-full px-3 py-1 text-xs font-medium">
                      <%= feed_badge_label %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_production_date&.strftime("%d %b %Y") || "-" %></td>
                  <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_arrival_date&.strftime("%d %b %Y") || "-" %></td>
                  <td class="whitespace-nowrap px-5 py-4 text-right font-semibold text-stone-900"><%= forecast.quantity_available || "-" %></td>
                  <td class="whitespace-nowrap px-5 py-4">
                    <% status_label, status_classes = import_tracking_status_badge(forecast) %>
                    <span class="<%= status_classes %> inline-flex items-center rounded-full px-3 py-1 text-xs font-medium"><%= status_label %></span>
                  </td>
                </tr>
                <% next %>
              <% end %>
              <% item = row %>
              <% forecast = item.supply_forecast %>
              <% sales_interest = item.sales_interests.build(status: :watching) %>
              <% detail_modal_key = "detail-#{item.id}" %>
              <% form_modal_key = "form-#{item.id}" %>
              <tr class="hover:bg-stone-50/80">
                <% unless import_file_flow? && !sales_mode? %>
                  <td class="whitespace-nowrap px-5 py-4">
                    <div class="font-semibold text-stone-900"><%= item.status_incoming? ? incoming_stock_reference(item) : "รอสร้าง" %></div>
                    <% unless sales_mode? %>
                      <div class="text-xs text-stone-500"><%= item.stock_plan.plan_no %></div>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-5 py-4">
                  <div class="font-medium text-stone-900"><%= forecast.model_label || forecast.model_code %></div>
                  <div class="text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></div>
                </td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <%= forecast_color_swatch(forecast) %>
                    <div class="font-medium text-stone-900"><%= forecast.color_name || "-" %></div>
                  </div>
                </td>
                <% if import_file_flow? && !sales_mode? %>
                  <td class="whitespace-nowrap px-5 py-4">
                    <% feed_badge_label, feed_badge_classes = import_source_badge(forecast) %>
                    <span class="<%= feed_badge_classes %> inline-flex items-center rounded-full px-3 py-1 text-xs font-medium">
                      <%= feed_badge_label %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_production_date&.strftime("%d %b %Y") || "-" %></td>
                  <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_arrival_date&.strftime("%d %b %Y") || "-" %></td>
                <% else %>
                  <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= stock_workspace_location(item) %></td>
                <% end %>
                <td class="whitespace-nowrap px-5 py-4 text-right font-semibold text-stone-900"><%= item.selected_quantity %></td>
                <% if sales_mode? %>
                  <td class="whitespace-nowrap px-5 py-4">
                    <div class="font-medium text-stone-900"><%= stock_workspace_arrival_label(item) %></div>
                    <div class="text-xs text-stone-500">
                      <% if forecast.estimated_arrival_date.present? %>
                        พร้อมรับเข้า <%= forecast.estimated_arrival_date.strftime("%d %b %Y") %>
                      <% else %>
                        รอข้อมูล ETA
                      <% end %>
                    </div>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex flex-col items-start gap-2">
                      <div class="font-medium text-stone-900"><%= sales_interest_count_display(item) %></div>
                      <% if item.sales_interests.any? %>
                        <button type="button"
                                data-action="sales-interest-modal#open"
                                data-sales-interest-modal-key-param="<%= detail_modal_key %>"
                                class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-stone-200 bg-[#fff1f2] text-[#e20712] shadow-sm transition hover:border-[#fecdd3] hover:bg-[#ffe4e6] hover:text-[#be123c]"
                                aria-label="ดูรายละเอียดการติดตาม">
                          <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                            <path d="M10 4c4.394 0 7.565 3.159 8.718 5.04a1.75 1.75 0 0 1 0 1.92C17.565 12.841 14.394 16 10 16s-7.565-3.159-8.718-5.04a1.75 1.75 0 0 1 0-1.92C2.435 7.159 5.606 4 10 4Zm0 1.5c-3.693 0-6.44 2.667-7.441 4.5 1.001 1.833 3.748 4.5 7.441 4.5s6.44-2.667 7.441-4.5C16.44 8.167 13.693 5.5 10 5.5Zm0 1.5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 1.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/>
                          </svg>
                        </button>
                      <% end %>
                    </div>
                  </td>
                  <td class="px-5 py-4">
                    <button type="button"
                            data-action="sales-interest-modal#open"
                            data-sales-interest-modal-key-param="<%= form_modal_key %>"
                            class="app-btn-primary inline-flex items-center rounded-xl px-3 py-2 text-xs font-medium transition">
                      ติดตาม
                    </button>
                  </td>
                <% else %>
                  <td class="whitespace-nowrap px-5 py-4">
                    <% if item.status_incoming? %>
                      <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">กำลังเข้า</span>
                    <% else %>
                      <span class="inline-flex items-center rounded-full bg-sky-100 px-3 py-1 text-xs font-medium text-sky-800">สั่งเข้าแล้ว</span>
                    <% end %>
                  </td>
                  <% unless import_file_flow? %>
                    <td class="px-5 py-4">
                      <div class="flex flex-col items-start gap-2">
                        <div class="font-medium text-stone-900"><%= item.stock_plan.display_title %></div>
                        <%= link_to "ดูรายละเอียด", stock_order_path(item.stock_plan), class: "inline-flex items-center rounded-xl border border-stone-300 px-3 py-2 text-xs font-medium text-stone-700 transition hover:bg-stone-100" %>
                      </div>
                    </td>
                  <% end %>
                <% end %>
              </tr>
              <% if sales_mode? %>
                <% if item.sales_interests.any? %>
                  <% content_for :page_overlays do %>
                    <div data-sales-interest-modal-target="panel"
                         data-modal-key-value="<%= detail_modal_key %>"
                         data-action="click->sales-interest-modal#closeOnBackdrop"
                         class="hidden fixed inset-0 z-[80] overflow-y-auto bg-stone-950/45 p-4">
                      <div class="mx-auto my-4 flex min-h-0 w-full max-w-2xl flex-col overflow-hidden rounded-lg border border-stone-200 bg-white shadow-2xl sm:my-8 sm:max-h-[calc(100vh-4rem)]">
                        <div class="shrink-0 flex items-start justify-between border-b border-stone-200 px-6 py-5">
                          <div>
                            <p class="app-eyebrow text-xs font-semibold uppercase tracking-[0.18em]">Sales Detail</p>
                            <h3 class="mt-2 text-xl font-semibold text-stone-900"><%= forecast.model_label || forecast.model_code %></h3>
                            <p class="mt-1 text-sm text-stone-500"><%= sales_interest_count_value(item) %> รายการติดตาม</p>
                          </div>
                          <button type="button"
                                  data-action="sales-interest-modal#close"
                                  class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-stone-200 text-stone-500 transition hover:bg-stone-50 hover:text-stone-900">
                            <span class="text-lg leading-none">&times;</span>
                          </button>
                        </div>

                        <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-6 py-5">
                          <% item.sales_interests.order(created_at: :desc).each do |interest| %>
                            <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
                              <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                  <div class="font-medium text-stone-900"><%= interest.sales_name %></div>
                                  <div class="text-sm text-stone-500"><%= interest.branch_name %></div>
                                </div>
                                <span class="inline-flex items-center rounded-full bg-stone-200 px-3 py-1 text-xs font-medium text-stone-700">
                                  <%= sales_interest_status_label(interest) %>
                                </span>
                              </div>
                              <% if interest.note.present? %>
                                <p class="mt-3 text-sm leading-6 text-stone-600"><%= interest.note %></p>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>

                <% content_for :page_overlays do %>
                  <div data-sales-interest-modal-target="panel"
                       data-modal-key-value="<%= form_modal_key %>"
                       data-action="click->sales-interest-modal#closeOnBackdrop"
                       class="hidden fixed inset-0 z-[80] overflow-y-auto bg-stone-950/45 p-4">
                    <div class="mx-auto my-4 flex min-h-0 w-full max-w-2xl flex-col overflow-hidden rounded-lg border border-stone-200 bg-white shadow-2xl sm:my-8 sm:max-h-[calc(100vh-4rem)]">
                      <div class="shrink-0 flex items-start justify-between border-b border-stone-200 px-6 py-5">
                        <div>
                          <p class="app-eyebrow text-xs font-semibold uppercase tracking-[0.18em]">Sales Tracking</p>
                          <h3 class="mt-2 text-xl font-semibold text-stone-900">ติดตามรถที่กำลังเข้า</h3>
                          <p class="mt-1 text-sm text-stone-500">
                            <%= forecast.model_label || forecast.model_code %> • <%= stock_workspace_arrival_label(item) %>
                          </p>
                        </div>
                        <button type="button"
                                data-action="sales-interest-modal#close"
                                class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-stone-200 text-stone-500 transition hover:bg-stone-50 hover:text-stone-900">
                          <span class="text-lg leading-none">&times;</span>
                        </button>
                      </div>

                      <div class="min-h-0 flex-1 space-y-5 overflow-y-auto px-6 py-5">
                        <div class="grid gap-4 sm:grid-cols-2">
                          <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Model</p>
                            <p class="mt-2 font-semibold text-stone-900"><%= forecast.model_label || forecast.model_code %></p>
                            <p class="mt-1 text-sm text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></p>
                          </div>
                          <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Location</p>
                            <p class="mt-2 font-semibold text-stone-900"><%= stock_workspace_location(item) %></p>
                            <p class="mt-1 text-sm text-stone-500"><%= stock_workspace_arrival_label(item) %></p>
                          </div>
                        </div>

                        <p class="text-sm leading-6 text-stone-600">
                          การติดตามไม่เท่ากับการจอง สามารถบันทึกได้เรื่อย ๆ เพื่อสะท้อน demand ให้ฝ่ายจัดสรรเห็นว่ารถรุ่นนี้มีความต้องการมากน้อยแค่ไหน
                        </p>

                        <%= render "sales_interests/form",
                                   sales_interest: sales_interest,
                                   stock_plan_item: item,
                                   return_tab: @active_tab,
                                   cancel_action: "sales-interest-modal#close" %>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</section>
