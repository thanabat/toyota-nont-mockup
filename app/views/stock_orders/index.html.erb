<% content_for :title, "รายการสั่งเข้า Stock" %>

<section class="space-y-8">
  <div class="app-soft-card flex flex-col gap-4 rounded-3xl border p-8 shadow-sm lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">Allocation Workspace</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900">รายการสั่งเข้า Stock</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-stone-600">
        มุมมองนี้ใช้ติดตาม forecast ที่ฝ่ายจัดสรรเลือกสั่งเข้า stock แล้ว แม้รถจะยังไม่พร้อมขาย แต่ฝ่ายขายสามารถใช้วางแผนล่วงหน้าได้ในอนาคต
      </p>
    </div>

  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <div class="app-soft-card rounded-3xl border p-6 shadow-sm">
      <p class="text-sm text-stone-500">จำนวนรายการสั่ง</p>
      <p class="mt-3 text-3xl font-semibold text-stone-900"><%= @stock_orders.count %></p>
    </div>
    <div class="rounded-3xl border border-sky-200 bg-sky-50 p-6 shadow-sm">
      <p class="text-sm text-sky-700">Forecast ที่ถูกสั่งแล้ว</p>
      <p class="mt-3 text-3xl font-semibold text-sky-900"><%= @stock_orders.sum { |order| order.stock_plan_items.size } %></p>
    </div>
    <div class="rounded-3xl border border-emerald-200 bg-emerald-50 p-6 shadow-sm">
      <p class="text-sm text-emerald-700">จำนวนที่สั่งรวม</p>
      <p class="mt-3 text-3xl font-semibold text-emerald-900"><%= @stock_orders.sum(&:total_selected_quantity) %></p>
    </div>
  </div>

  <div class="app-soft-card overflow-hidden rounded-3xl border shadow-sm">
    <div class="border-b border-stone-200 px-6 py-4">
      <h2 class="text-lg font-semibold text-stone-900">รายการทั้งหมด</h2>
    </div>

    <div class="divide-y divide-stone-200">
      <% @stock_orders.each do |stock_order| %>
        <div class="flex flex-col gap-4 px-6 py-5 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h3 class="text-lg font-semibold text-stone-900"><%= stock_order.display_title %></h3>
              <span class="app-btn-secondary rounded-full px-3 py-1 text-xs font-medium"><%= stock_order.plan_no %></span>
            </div>
            <p class="mt-2 text-sm text-stone-500">
              สร้างโดย <span class="font-medium text-stone-700"><%= stock_order.requested_by %></span>
              • <%= stock_order.stock_plan_items.size %> forecast lines
              • จำนวนรวม <%= stock_order.total_selected_quantity %>
              • กำลังเข้า <%= stock_order.incoming_items_count %>
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800">
              <%= stock_order.status.humanize %>
            </span>
            <%= link_to "ดูรายละเอียด", stock_order_path(stock_order), class: "inline-flex items-center rounded-xl border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 transition hover:bg-stone-100" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
