<% content_for :title, @stock_order.display_title %>

<section class="space-y-8">
  <div class="app-breadcrumb rounded-2xl px-5 py-3">
    <nav class="flex flex-wrap items-center gap-2 text-sm">
      <%= link_to "Stock", stock_orders_path, class: "app-breadcrumb-link font-medium transition" %>
      <span class="text-[#fda4af]">/</span>
      <span class="app-breadcrumb-current font-medium"><%= @stock_order.display_title %></span>
    </nav>
  </div>

  <div class="app-soft-card flex flex-col gap-4 rounded-xl border p-8 shadow-sm lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">Stock Order Detail</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900"><%= @stock_order.display_title %></h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-stone-600">
        <span class="font-medium text-stone-800"><%= @stock_order.plan_no %></span>
        เป็นรายการที่ฝ่ายจัดสรรสั่ง forecast เข้ามาเป็น stock ล่วงหน้า ก่อนจะกลายเป็นรถที่รับเข้าและพร้อมขายจริง
      </p>
    </div>

  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <div class="app-soft-card rounded-xl border p-6 shadow-sm">
      <p class="text-sm text-stone-500">สถานะ</p>
      <p class="mt-3 text-2xl font-semibold text-stone-900"><%= @stock_order.status.humanize %></p>
    </div>
    <div class="app-soft-card rounded-xl border p-6 shadow-sm">
      <p class="text-sm text-stone-500">จำนวน Forecast Lines</p>
      <p class="mt-3 text-2xl font-semibold text-stone-900"><%= @stock_order.stock_plan_items.size %></p>
    </div>
    <div class="rounded-xl border border-[#fecdd3] bg-[#fff1f2] p-6 shadow-sm">
      <p class="text-sm text-[#be123c]">จำนวนที่สั่งรวม</p>
      <p class="mt-3 text-2xl font-semibold text-[#881337]"><%= @stock_order.total_selected_quantity %></p>
    </div>
    <div class="app-soft-card rounded-xl border p-6 shadow-sm">
      <p class="text-sm text-stone-500">กำลังเข้าแล้ว</p>
      <p class="mt-3 text-2xl font-semibold text-stone-900"><%= @stock_order.incoming_items_count %></p>
    </div>
  </div>

  <div class="app-soft-card overflow-hidden rounded-xl border shadow-sm">
    <div class="border-b border-stone-200 px-6 py-4">
      <h2 class="text-lg font-semibold text-stone-900">Forecast ที่ถูกสั่งเข้า Stock</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-stone-200 text-sm">
        <thead class="bg-stone-50 text-left text-stone-500">
            <tr>
              <th class="px-5 py-3 font-medium">Forecast</th>
              <th class="px-5 py-3 font-medium">Model</th>
              <th class="px-5 py-3 font-medium">Color</th>
              <th class="px-5 py-3 font-medium">สถานะ</th>
              <th class="px-5 py-3 font-medium text-right">Qty ที่สั่ง</th>
              <th class="px-5 py-3 font-medium">Prod. Date</th>
              <th class="px-5 py-3 font-medium">ETA</th>
              <th class="px-5 py-3 font-medium">หมายเหตุ</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100 bg-white">
          <% @stock_order.stock_plan_items.each do |item| %>
            <% forecast = item.supply_forecast %>
            <tr class="hover:bg-stone-50/80">
              <td class="whitespace-nowrap px-5 py-4 font-mono text-xs text-stone-500"><%= forecast.source_key %></td>
              <td class="px-5 py-4">
                <div class="font-medium text-stone-900"><%= forecast.model_label || forecast.model_code %></div>
                <div class="text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></div>
              </td>
              <td class="px-5 py-4">
                <div class="font-medium text-stone-900"><%= forecast.color_name || "-" %></div>
                <div class="text-stone-500"><%= forecast.color_code.presence || "-" %></div>
              </td>
              <td class="whitespace-nowrap px-5 py-4">
                <% status_classes = item.status_incoming? ? "bg-emerald-100 text-emerald-800" : "bg-sky-100 text-sky-800" %>
                <% status_label = item.status_incoming? ? "กำลังเข้า" : "สั่งแล้ว" %>
                <span class="<%= status_classes %> inline-flex items-center rounded-full px-3 py-1 text-xs font-medium"><%= status_label %></span>
              </td>
              <td class="whitespace-nowrap px-5 py-4 text-right font-semibold text-stone-900"><%= item.selected_quantity %></td>
              <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_production_date&.strftime("%d %b %Y") || "-" %></td>
              <td class="whitespace-nowrap px-5 py-4 text-stone-600"><%= forecast.estimated_arrival_date&.strftime("%d %b %Y") || "-" %></td>
              <td class="px-5 py-4 text-stone-600"><%= item.note.presence || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
