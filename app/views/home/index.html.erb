<% content_for :title, "Toyota Stock Prototype" %>

<section class="space-y-8">
  <div class="app-soft-card rounded-3xl border p-8 shadow-sm">
    <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">Prototype Entry</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-stone-900">เลือกแนวคิดที่ต้องการนำเสนอ</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 text-stone-600">
      หน้านี้เป็นทางเข้าแยกของ 2 ไอเดียสำหรับ validate กับ user โดยให้แต่ละ flow มีจุดเริ่มต้นของตัวเอง
      แล้วค่อยพาไปดูหน้าภายในที่สอดคล้องกับ use case ของแนวคิดนั้น
    </p>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <div class="app-soft-card rounded-3xl border p-7 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="app-eyebrow text-xs font-semibold uppercase tracking-[0.2em]">Idea 01</p>
          <h2 class="mt-2 text-2xl font-semibold text-stone-900">Auto Sync Flow</h2>
          <p class="mt-3 text-sm leading-6 text-stone-600">
            ข้อมูลจากบริษัทแม่ไหลเข้าระบบเราแบบอัตโนมัติ ฝ่ายจัดสรรเริ่มจากหน้า Forecast แล้วค่อยไหลต่อไปสู่ Stock และฝ่ายขาย
          </p>
        </div>
        <% if auto_sync_flow? %>
          <span class="inline-flex items-center rounded-full bg-[#fff1f2] px-3 py-1 text-xs font-semibold text-[#be123c]">กำลังใช้งาน</span>
        <% end %>
      </div>

      <ul class="mt-6 space-y-2 text-sm text-stone-600">
        <li>เหมาะกับแนวคิด integration แบบ sync เข้าโดยตรง</li>
        <li>จุดเริ่มต้นของฝ่ายจัดสรรคือ Forecast</li>
        <li>ปลายทางยังไหลต่อไป Stock workspace เดิม</li>
      </ul>

      <div class="mt-6">
        <%= button_to "เข้า Idea 01",
                      prototype_flow_path,
                      method: :patch,
                      params: { flow: :auto_sync, return_to: (sales_mode? ? stock_orders_path(tab: :incoming) : forecasts_path) },
                      class: "app-btn-primary inline-flex items-center rounded-xl px-5 py-3 text-sm font-medium transition" %>
      </div>
    </div>

    <div class="app-soft-card rounded-3xl border p-7 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="app-eyebrow text-xs font-semibold uppercase tracking-[0.2em]">Idea 02</p>
          <h2 class="mt-2 text-2xl font-semibold text-stone-900">Import File Flow</h2>
          <p class="mt-3 text-sm leading-6 text-stone-600">
            ฝ่ายจัดสรร export รายงานจากระบบบริษัทแม่ด้วยตัวเอง แล้วนำ daily, weekly, monthly file เข้าระบบเราเพื่ออัปเดตข้อมูลต่อ
          </p>
        </div>
        <% if import_file_flow? %>
          <span class="inline-flex items-center rounded-full bg-[#fff1f2] px-3 py-1 text-xs font-semibold text-[#be123c]">กำลังใช้งาน</span>
        <% end %>
      </div>

      <ul class="mt-6 space-y-2 text-sm text-stone-600">
        <li>เหมาะกับแนวคิด export/import จากระบบบริษัทแม่</li>
        <li>จุดเริ่มต้นของฝ่ายจัดสรรคือหน้า Import File</li>
        <li>ปลายทางยังใช้ Stock workspace ชุดเดิมเหมือนกัน</li>
      </ul>

      <div class="mt-6">
        <%= button_to "เข้า Idea 02",
                      prototype_flow_path,
                      method: :patch,
                      params: { flow: :import_file, return_to: (sales_mode? ? stock_orders_path(tab: :incoming) : import_flow_path) },
                      class: "app-btn-secondary inline-flex items-center rounded-xl px-5 py-3 text-sm font-medium transition" %>
      </div>
    </div>
  </div>
</section>
