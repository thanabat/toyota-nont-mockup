<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Toyota Nont Mockup" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Toyota Nont Mockup">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body min-h-screen text-stone-900">
    <main class="mx-auto min-h-screen w-full max-w-[1500px] px-4 py-4 lg:px-6 lg:py-6">
      <% if current_page?(root_path) %>
        <div class="app-shell-panel min-h-[calc(100vh-2rem)] rounded-[2rem] border p-4 backdrop-blur lg:p-8">
          <% if notice.present? %>
            <div class="mb-4 rounded-2xl border border-[#fecdd3] bg-[#fff1f2] px-4 py-3 text-sm text-[#be123c]">
              <%= notice %>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mb-4 rounded-2xl border border-[#fecdd3] bg-[#fff1f2] px-4 py-3 text-sm text-[#be123c]">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      <% else %>
        <div class="grid min-h-[calc(100vh-2rem)] gap-4 lg:grid-cols-[260px_minmax(0,1fr)]">
          <aside class="app-sidebar-panel rounded-[2rem] border p-5 backdrop-blur">
            <div class="flex h-full flex-col">
              <div class="app-soft-tint rounded-[1.5rem] border px-5 py-6">
                <p class="app-eyebrow text-xs font-semibold uppercase tracking-[0.3em]">Toyota</p>
                <h1 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950">Stock Flow</h1>
                <p class="mt-2 text-sm leading-6 text-stone-500">Prototype สำหรับเทียบ 2 แนวคิดการรับข้อมูลจากบริษัทแม่ ก่อนข้อมูลจะไหลต่อไปสู่ stock และฝ่ายขาย</p>
              </div>

              <nav class="mt-6 space-y-2">
                <%= link_to root_path, class: sidebar_link_classes(root_path) do %>
                  <span class="app-nav-icon inline-flex h-9 w-9 items-center justify-center rounded-2xl"><%= sidebar_icon(:home) %></span>
                  <span>Overview</span>
                <% end %>
                <% if allocation_mode? && auto_sync_flow? %>
                  <%= link_to forecasts_path, class: sidebar_link_classes(forecasts_path) do %>
                    <span class="app-nav-icon inline-flex h-9 w-9 items-center justify-center rounded-2xl"><%= sidebar_icon(:forecast) %></span>
                    <span>Forecast</span>
                  <% end %>
                <% elsif allocation_mode? && import_file_flow? %>
                  <%= link_to import_flow_path, class: sidebar_link_classes(import_flow_path) do %>
                    <span class="app-nav-icon inline-flex h-9 w-9 items-center justify-center rounded-2xl"><%= sidebar_icon(:orders) %></span>
                    <span>Import File</span>
                  <% end %>
                <% end %>
                <%= link_to stock_orders_path, class: sidebar_link_classes(stock_orders_path) do %>
                  <span class="app-nav-icon inline-flex h-9 w-9 items-center justify-center rounded-2xl"><%= sidebar_icon(:stock) %></span>
                  <span><%= import_file_flow? && allocation_mode? ? "รายการติดตาม" : "Stock" %></span>
                <% end %>
              </nav>

              <div class="app-soft-tint mt-8 rounded-[1.5rem] border px-5 py-4 text-sm text-stone-600">
                <p class="font-medium text-stone-900">Demo Notes</p>
                <p class="mt-2 leading-6">
                  <% if sales_mode? %>
                    ใช้โหมดนี้เพื่อดู incoming stock, กด `เช็คสถานะล่าสุด` แล้วให้ฝ่ายขายเริ่ม `ติดตาม` รายการที่สนใจได้
                  <% elsif import_file_flow? %>
                    ใช้โหมดนี้เพื่อจำลองการ export ไฟล์จากระบบแม่ แล้วนำ daily, weekly, monthly เข้ามาอัปเดต stock workspace ของเรา
                  <% else %>
                    กด `Sync` เพื่อจำลองข้อมูลตอบกลับจากบริษัทแม่ และดูการไหลของรายการจาก forecast ไปเป็น incoming stock
                  <% end %>
                </p>
              </div>

              <div class="app-soft-card mt-auto rounded-[1.5rem] border px-5 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-400">Workspace</p>
                <p class="mt-2 text-sm font-medium text-stone-900"><%= workspace_mode_label %></p>
                <p class="mt-1 text-sm text-stone-500"><%= workspace_mode_description %></p>
                <div class="mt-4 rounded-2xl border border-stone-200 bg-white/80 p-2">
                  <p class="px-2 pb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-stone-400">Prototype Flow</p>
                  <div class="grid grid-cols-2 gap-2">
                    <%= button_to "Auto Sync",
                                  prototype_flow_path,
                                  method: :patch,
                                  params: { flow: :auto_sync, return_to: forecasts_path },
                                  class: prototype_flow_switch_classes(:auto_sync) %>
                    <%= button_to "Import File",
                                  prototype_flow_path,
                                  method: :patch,
                                  params: { flow: :import_file, return_to: import_flow_path },
                                  class: prototype_flow_switch_classes(:import_file) %>
                  </div>
                </div>
                <div class="mt-3 rounded-2xl border border-stone-200 bg-white/80 p-2">
                  <p class="px-2 pb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-stone-400">View Mode</p>
                  <div class="grid grid-cols-2 gap-2">
                    <%= button_to "Allocation",
                                  workspace_mode_path,
                                  method: :patch,
                                  params: { mode: :allocation, return_to: request.fullpath },
                                  class: workspace_mode_switch_classes(:allocation) %>
                    <%= button_to "Sales",
                                  workspace_mode_path,
                                  method: :patch,
                                  params: { mode: :sales, return_to: request.fullpath },
                                  class: workspace_mode_switch_classes(:sales) %>
                  </div>
                </div>
                <div class="mt-3 border-t border-stone-200 pt-3">
                  <%= button_to "Reset Demo",
                                demo_reset_path,
                                method: :post,
                                params: { return_to: request.fullpath },
                                class: "inline-flex w-full items-center justify-center rounded-xl border border-stone-200 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-stone-600 transition hover:bg-stone-50 hover:text-stone-900" %>
                </div>
              </div>
            </div>
          </aside>

          <div class="app-shell-panel rounded-[2rem] border p-4 backdrop-blur lg:p-6">
            <% if notice.present? %>
              <div class="mb-4 rounded-2xl border border-[#fecdd3] bg-[#fff1f2] px-4 py-3 text-sm text-[#be123c]">
                <%= notice %>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="mb-4 rounded-2xl border border-[#fecdd3] bg-[#fff1f2] px-4 py-3 text-sm text-[#be123c]">
                <%= alert %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      <% end %>
    </main>
  </body>
</html>
