<% content_for :title, "ติดตาม Stock กำลังเข้า" %>

<% forecast = @stock_plan_item.supply_forecast %>

<section class="space-y-8">
  <div class="app-breadcrumb rounded-2xl px-5 py-3">
    <nav class="flex flex-wrap items-center gap-2 text-sm">
      <%= link_to "Stock", stock_orders_path(tab: @return_tab), class: "app-breadcrumb-link font-medium transition" %>
      <span class="text-[#fda4af]">/</span>
      <span class="app-breadcrumb-current font-medium">ติดตาม Stock กำลังเข้า</span>
    </nav>
  </div>

  <div class="app-soft-card grid gap-6 rounded-3xl border p-8 shadow-sm lg:grid-cols-[1.1fr_0.9fr]">
    <div>
      <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">Sales Workspace</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900">ติดตาม Stock กำลังเข้า</h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-600">
        ฝ่ายขายสามารถ mark รายการนี้ไว้ก่อน เพื่อใช้ติดตามรถที่กำลังเข้าและเตรียมแผนเสนอขายล่วงหน้าได้
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Model</p>
          <p class="mt-2 font-semibold text-stone-900"><%= forecast.model_label || forecast.model_code %></p>
          <p class="mt-1 text-sm text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">In Stock</p>
          <p class="mt-2 font-semibold text-stone-900"><%= stock_workspace_arrival_label(@stock_plan_item) %></p>
          <p class="mt-1 text-sm text-stone-500"><%= forecast.estimated_arrival_date&.strftime("%d %b %Y") || "-" %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Location</p>
          <p class="mt-2 font-semibold text-stone-900"><%= stock_workspace_location(@stock_plan_item) %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">รายการสั่งเข้า Stock</p>
          <p class="mt-2 font-semibold text-stone-900"><%= @stock_plan_item.stock_plan.display_title %></p>
          <p class="mt-1 text-sm text-stone-500"><%= @stock_plan_item.stock_plan.plan_no %></p>
        </div>
      </div>
    </div>

    <div class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
      <%= form_with model: @sales_interest, class: "space-y-5" do |form| %>
        <%= form.hidden_field :stock_plan_item_id, value: @stock_plan_item.id %>
        <%= hidden_field_tag :return_tab, @return_tab %>

        <div>
          <%= form.label :sales_name, "ชื่อเซลล์", class: "mb-2 block text-sm font-medium text-stone-800" %>
          <%= form.text_field :sales_name, class: "block w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm text-stone-900 shadow-sm focus:border-stone-500 focus:outline-none", placeholder: "เช่น นัทธพงศ์" %>
          <% @sales_interest.errors.full_messages_for(:sales_name).each do |message| %>
            <p class="mt-2 text-xs text-[#be123c]"><%= message %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :branch_name, "สาขา", class: "mb-2 block text-sm font-medium text-stone-800" %>
          <%= form.text_field :branch_name, class: "block w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm text-stone-900 shadow-sm focus:border-stone-500 focus:outline-none", placeholder: "เช่น โชว์รูมบางบัวทอง" %>
          <% @sales_interest.errors.full_messages_for(:branch_name).each do |message| %>
            <p class="mt-2 text-xs text-[#be123c]"><%= message %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :status, "สถานะความสนใจ", class: "mb-2 block text-sm font-medium text-stone-800" %>
          <%= form.select :status,
                          [["กำลังติดตาม", "watching"], ["มีลูกค้ารอ", "customer_waiting"]],
                          {},
                          class: "block w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm text-stone-900 shadow-sm focus:border-stone-500 focus:outline-none" %>
        </div>

        <div>
          <%= form.label :note, "หมายเหตุ", class: "mb-2 block text-sm font-medium text-stone-800" %>
          <%= form.text_area :note, rows: 4, class: "block w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm text-stone-900 shadow-sm focus:border-stone-500 focus:outline-none", placeholder: "เช่น มีลูกค้ากำลังรอสีนี้อยู่ 1 ราย" %>
        </div>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <%= form.submit "บันทึกการติดตาม", class: "app-btn-primary inline-flex cursor-pointer items-center rounded-2xl px-4 py-3 text-sm font-medium transition" %>
          <%= link_to "กลับไป Stock", stock_orders_path(tab: @return_tab), class: "app-btn-ghost inline-flex items-center rounded-2xl px-4 py-3 text-sm font-medium transition" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
