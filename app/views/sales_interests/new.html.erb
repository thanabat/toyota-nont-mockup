<% content_for :title, "ติดตาม Stock กำลังเข้า" %>

<% forecast = @stock_plan_item.supply_forecast %>

<section class="space-y-8">
  <div class="app-breadcrumb rounded-2xl px-5 py-3">
    <nav class="flex flex-wrap items-center gap-2 text-sm">
      <%= link_to "Stock", stock_orders_path(tab: @return_tab), class: "app-breadcrumb-link font-medium transition" %>
      <span class="text-[#fda4af]">/</span>
      <span class="app-breadcrumb-current font-medium">ติดตาม Stock กำลังเข้า</span>
    </nav>
  </div>

  <div class="app-soft-card grid gap-6 rounded-xl border p-8 shadow-sm lg:grid-cols-[1.1fr_0.9fr]">
    <div>
      <p class="app-eyebrow text-sm font-medium uppercase tracking-[0.2em]">Sales Workspace</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900">ติดตาม Stock กำลังเข้า</h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-600">
        ฝ่ายขายสามารถบันทึกการติดตามรายการนี้ได้เรื่อย ๆ เพื่อสะท้อนความต้องการของแต่ละเซลล์ให้ฝ่ายจัดสรรเห็นก่อนรถเข้าจริง โดยยังไม่ถือว่าเป็นการจอง
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Model</p>
          <p class="mt-2 font-semibold text-stone-900"><%= forecast.model_label || forecast.model_code %></p>
          <p class="mt-1 text-sm text-stone-500"><%= [forecast.model_code, forecast.grade].compact.join(" • ").presence || "-" %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">In Stock</p>
          <p class="mt-2 font-semibold text-stone-900"><%= stock_workspace_arrival_label(@stock_plan_item) %></p>
          <p class="mt-1 text-sm text-stone-500"><%= forecast.estimated_arrival_date&.strftime("%d %b %Y") || "-" %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">Location</p>
          <p class="mt-2 font-semibold text-stone-900"><%= stock_workspace_location(@stock_plan_item) %></p>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-400">รายการสั่งเข้า Stock</p>
          <p class="mt-2 font-semibold text-stone-900"><%= @stock_plan_item.stock_plan.display_title %></p>
          <p class="mt-1 text-sm text-stone-500"><%= @stock_plan_item.stock_plan.plan_no %></p>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
      <%= render "form",
                 sales_interest: @sales_interest,
                 stock_plan_item: @stock_plan_item,
                 return_tab: @return_tab %>
    </div>
  </div>
</section>
